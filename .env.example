# LLM API配置（支持 OpenAI SDK 格式的任意 LLM API）
# 推荐使用阿里百炼平台qwen-plus模型：https://bailian.console.aliyun.com/
# 注意消耗较大，可先进行小于40轮的模拟尝试
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== ZEP记忆图谱配置 =====
# 每月免费额度即可支撑简单使用：https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env文件中就不要出现下面的配置项
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here

# ===== Множитель демографических агентов (опционально) =====
# Для абстрактных групп (LocalResident, Citizen, Population) генератор
# по умолчанию создаёт N индивидов вместо одного коллективного аккаунта.
SIMULATION_DEMOGRAPHIC_MULTIPLIER=5

# ===== Региональный контекст симуляции (опционально) =====
# Добавляется в системный промпт генератора персон. Пример для Казахстана:
# SIMULATION_REGION_CONTEXT="Контекст: симуляция аудитории Threads в Казахстане. Города: Алматы, Астана, Шымкент. Имена — казахские/русские/уйгурские/корейские. Темы: тенге, акимат, выборы, ЖКХ."
SIMULATION_REGION_CONTEXT=

# ===== Язык контента индивидуальных агентов (опционально) =====
# Переопределяет языковую инструкцию для индивидуальных персон/ответов.
# Институциональные аккаунты (СМИ, министерства) сохраняют язык UI.
# Пример для билингвального Казахстана (русский + казахский с code-switching):
# SIMULATION_AGENT_LANGUAGE="Распределяй языки по персоне: ~55% русский, ~25% казахский, ~20% билингв с code-switching. Вкрапления: «бірақ», «жарайды», «ағай». Не переводи на чистый литературный язык."
SIMULATION_AGENT_LANGUAGE=